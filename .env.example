# Railway 환경변수 예시 — 실제 값은 Railway 대시보드 Variables 탭에 입력하세요.
# (이 파일을 .env 로 복사하면 로컬에서도 동작합니다. .env 는 git에 커밋되지 않습니다.)

# Claude API Key (필수)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 모델 (선택 — 미지정 시 아래 기본값 사용)
# ② 구조 인덱싱 (싼 패스)
ANTHROPIC_INDEX_MODEL=claude-3-5-haiku-20241022
# ③ 세부과제 추출 (비전, 정확도 핵심 — Opus)
ANTHROPIC_EXTRACT_MODEL=claude-opus-4-20250514
